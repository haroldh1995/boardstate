# Copy this file to `android-app/keystore.properties` to override the default auto-generated upload key.
# If this file is missing, Gradle will generate `android-app/keystore/boardstate-upload.jks`
# on first release build so a clone can build APK/AAB without extra coding.

storeFile=keystore/boardstate-upload.jks
storePassword=boardstateUpload123!
keyAlias=boardstateupload
keyPassword=boardstateUpload123!
dName=CN=BoardState Upload,O=BoardState,C=US
